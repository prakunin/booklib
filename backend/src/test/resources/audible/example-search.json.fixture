_enhanced":true,"name":"aax_22_32"},{"enhanced_codec":"LC_64_44100_stereo","format":"Enhanced","is_kindle_enhanced":true,"name":"aax_44_64"},{"enhanced_codec":"format4","format":"Format4","is_kindle_enhanced":false,"name":"format4"},{"enhanced_codec":"LC_128_44100_stereo","format":"Enhanced","is_kindle_enhanced":true,"name":"aax_44_128"},{"enhanced_codec":"mp42232","format":"Enhanced","is_kindle_enhanced":true,"name":"mp4_22_32"},{"enhanced_codec":"mp44464","format":"Enhanced","is_kindle_enhanced":true,"name":"mp4_44_64"},{"enhanced_codec":"mp444128","format":"Enhanced","is_kindle_enhanced":true,"name":"mp4_44_128"},{"enhanced_codec":"mp42264","format":"Enhanced","is_kindle_enhanced":true,"name":"mp4_22_64"},{"enhanced_codec":"aax","format":"Enhanced","is_kindle_enhanced":false,"name":"aax"}],"category_ladders":[{"ladder":[{"id":"18574426011","name":"Literature & Fiction"},{"id":"18574449011","name":"Classics"}],"root":"Genres"},{"ladder":[{"id":"18580606011","name":"Science Fiction & Fantasy"},{"id":"18580607011","name":"Fantasy"},{"id":"18580613011","name":"Dragons & Mythical Creatures"}],"root":"Genres"},{"ladder":[{"id":"18580606011","name":"Science Fiction & Fantasy"},{"id":"18580607011","name":"Fantasy"},{"id":"18580615011","name":"Epic"}],"root":"Genres"}],"content_delivery_type":"MultiPartBook","content_type":"Product","format_type":"unabridged","has_children":true,"is_adult_product":false,"is_listenable":true,"is_preview_enabled":false,"is_purchasability_suppressed":false,"is_vvab":false,"issue_date":"2021-09-16","language":"english","merchandising_summary":"This brand-new unabridged audiobook of The Return of the King, the third and final part of J. R. R. Tolkien’s epic adventure The Lord of the Rings, is read by the BAFTA Award-winning actor, director, and author Andy Serkis. The armies of the Dark Lord are massing as his evil shadow spreads...","narrators":[{"name":"Andy Serkis"}],"product_images":{"1000":"https://m.media-amazon.com/images/I/81t4kWqfUfL._SL1000_.jpg"},"publication_datetime":"2021-09-16T07:00:00Z","publication_name":"The Lord of the Rings","publisher_name":"Recorded Books","publisher_summary":"<p><b>This brand-new unabridged audiobook of </b><b><i>The Return of the King</i></b><b>, the third and final part of J. R. R. Tolkien’s epic adventure </b><b><i>The Lord of the Rings</i></b><b>, is read by the BAFTA Award-winning actor, director, and author Andy Serkis. </b></p> <p>The armies of the Dark Lord are massing as his evil shadow spreads even wider. Men, Dwarves, Elves, and Ents unite forces to battle against the Dark. Meanwhile, Frodo and Sam struggle further into Mordor in their heroic quest to destroy the One Ring. The devastating conclusion of J. R. R. Tolkien’s classic tale of adventure, begun in <i>The Fellowship of the Ring </i>and <i>The Two Towers</i>.</p>","rating":{"num_reviews":642,"overall_distribution":{"average_rating":4.930963855421687,"display_average_rating":"4.9","display_stars":5.0,"num_five_star_ratings":7854,"num_four_star_ratings":345,"num_one_star_ratings":7,"num_ratings":8300,"num_three_star_ratings":82,"num_two_star_ratings":12},"performance_distribution":{"average_rating":4.966936182500722,"display_average_rating":"5.0","display_stars":5.0,"num_five_star_ratings":6745,"num_four_star_ratings":152,"num_one_star_ratings":6,"num_ratings":6926,"num_three_star_ratings":16,"num_two_star_ratings":7},"story_distribution":{"average_rating":4.922564770589086,"display_average_rating":"4.9","display_stars":5.0,"num_five_star_ratings":6509,"num_four_star_ratings":302,"num_one_star_ratings":9,"num_ratings":6909,"num_three_star_ratings":70,"num_two_star_ratings":19}},"release_date":"2021-09-16","runtime_length_min":1312,"series":[{"asin":"B009CFOEGK","sequence":"3","title":"The Lord of the Rings","url":"/pd/The-Lord-of-the-Rings-Audiobook/B009CFOEGK"}],"sku":"BK_RECO_016050","sku_lite":"BK_RECO_016050","social_media_images":{"facebook":"https://m.media-amazon.com/images/I/51KBy8XxMzL._SL1