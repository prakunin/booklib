set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

pnpm := "pnpm"

# Show the release-tooling recipes available in this directory.
help:
    @just --list

# Install the pinned semantic-release tooling used by local and CI release tasks.
install:
    {{ pnpm }} install --frozen-lockfile

# Preview the next semantic-release result for the current checkout.
preview:
    {{ pnpm }} run release:dry-run

# Generate release notes for an explicit commit range.
range-notes:
    {{ pnpm }} run release:range-notes

# Run semantic-release for the current checkout.
run:
    {{ pnpm }} run release
