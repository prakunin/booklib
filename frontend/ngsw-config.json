{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "navigationUrls": [
    "/**",
    "!/api/**",
    "!/komga/**",
    "!/assets/embedpdf-frame.html"
  ],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/assets/favicon.svg",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "book-media-covers",
      "urls": [
        "/api/v1/media/book/*/thumbnail",
        "/api/v1/media/book/*/cover",
        "/api/v1/media/book/*/audiobook-thumbnail",
        "/api/v1/media/book/*/audiobook-cover"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 1000,
        "maxAge": "365d"
      }
    },
    {
      "name": "book-content",
      "urls": [
        "/api/v1/books/*/content"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "30d",
        "timeout": "10s"
      }
    },
    {
      "name": "book-downloads",
      "urls": [
        "/api/v1/books/*/download",
        "/api/v1/books/*/download-all",
        "/api/v1/books/*/files/*/download"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "30d",
        "timeout": "10s"
      },
      "cacheQueryOptions": {
        "ignoreSearch": true
      }
    },
    {
      "name": "api-passthrough",
      "urls": ["/api/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 0,
        "maxAge": "0u",
        "timeout": "0u"
      }
    }
  ]
}
